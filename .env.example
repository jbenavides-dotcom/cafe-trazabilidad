# Google OAuth Client ID — generar en Google Cloud Console
# Origins autorizados: http://localhost:5174 (dev) + https://jbenavides-dotcom.github.io (prod)
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Webhook n8n para email a John (creación nanolote) — opcional
VITE_N8N_WEBHOOK_NANOLOTE=https://jhona.app.n8n.cloud/webhook/nanolote-created

# Webhook n8n para eventos del flujo (opcional, alarmas Sergio/Ismelda)
# Si vacío, eventos solo en localStorage. Workflow recibe {tipo, bache, antes, despues, usuario, roles_objetivo}.
VITE_N8N_WEBHOOK_EVENTOS=
